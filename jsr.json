{
  "name": "@barf/bun-flaky-tests",
  "version": "0.1.1",
  "license": "MIT",
  "description": "Find the flaky tests in your Bun suite. SQLite-backed test-failure telemetry with a dark-themed HTML report.",
  "exports": {
    ".": "./src/mod.ts",
    "./preload": "./src/preload.ts",
    "./run-tracked": "./src/run-tracked.ts",
    "./report": "./src/report.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.sql",
      "README.md",
      "LICENSE",
      "jsr.json",
      "mrflaky.png"
    ],
    "exclude": [
      "tests/**",
      "**/*.test.ts",
      ".github/**",
      "node_modules/**",
      "bunfig.toml"
    ]
  }
}
